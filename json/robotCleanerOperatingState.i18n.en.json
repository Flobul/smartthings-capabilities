                    "dustBinFull": {
                        "label": "Dust bin full"
                    },
                    "stopped": {
                        "label": "Stopped"
                    },
                    "paused": {
                        "label": "Paused"
                    },
                    "unableToStartOrResume": {
                        "label": "Couldn't start"
                    },
                    "failedToFindChargingDock": {
                        "label": "Couldn't find location"
                    },
                    "charging": {
                        "label": "Charging"
                    },
                    "mopCleaningPadMissing": {
                        "label": "Mop missing"
                    },
                    "running": {
                        "label": "Cleaning"
                    },
                    "seekingCharger": {
                        "label": "Returning"
                    },
                    "unableToCompleteOperation": {
                        "label": "Couldn't complete"
                    },
                    "commandInvalidInState": {
                        "label": "Couldn't do action"
                    },
                    "stuck": {
                        "label": "Stuck"
                    },
                    "waterTankEmpty": {
                        "label": "Water tank empty"
                    },
                    "waterTankMissing": {
                        "label": "Water tank missing"
                    },
                    "docked": {
                        "label": "Fully charged"
                    },
                    "dustBinMissing": {
                        "label": "Dust bin missing"
                    },
                    "waterTankLidOpen": {
                        "label": "Water tank lid open"
                    }
                }
            }
        },
        "supportedOperatingStates": {
            "label": "supported operating states",
            "description": "Operational states supported by the robot cleaner",
            "displayTemplate": "{{device.label}} {{attribute}} was {{value}}",
            "i18n": {}
        },
        "supportedCommands": {
            "label": "supported commands",
            "description": "An optional list of all commands supported by the robot cleaner, regardless of its current state. Setting this list is required for some integrations that may dynamically add or remove commands from the supportedOperatingStateCommands attribute based on the device's current operating state. In such cases, the supportedCommands attribute should be set to the full list of commands, and the device configuration should be patched to use supportedCommands rather than supportedOperatingStateCommands in the automation/actions section. If the device configuration is not patched, supportedCommands will not affect the routine builder user interface.",
            "displayTemplate": "{{device.label}} {{attribute}} was {{value}}",
            "i18n": {}
        },
        "supportedOperatingStateCommands": {
            "label": "supported operating state commands",
            "description": "Current available operational state commands",
            "displayTemplate": "{{device.label}} {{attribute}} was {{value}}",
            "i18n": {}
        }
    },
    "commands": {
        "goHome": {
            "label": "Return",
            "description": "Return the robot cleaner to the charging dock",
            "arguments": {}
        },
        "start": {
            "label": "Start",
            "description": "Start the robot cleaner",
            "arguments": {}
        },
        "pause": {
            "label": "Pause",
            "description": "Pause the robot cleaner",
            "arguments": {}
        }
